{
    "name": "hexlet/code",
    "description": "A set of brain games implemented in PHP",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "BrainGames\\": "src/"
        },
        "files": [
            "src/Cli.php"
        ]
    },
    "authors": [
        {
            "name": "Dom",
            "email": "dinisvalee@mail.ru"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "wp-cli/php-cli-tools": "^0.13.0"
    },
    "bin": [
        "bin/brain-games",
        "bin/brain-even",
        "bin/brain-calc",
        "bin/brain-gcd",
        "bin/brain-progression",
        "bin/brain-prime"
    ],
    "require-dev": {
        "squizlabs/php_codesniffer": "^4.0"
    }
}